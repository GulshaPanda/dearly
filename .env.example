# =============================================================
# Dearly — Environment variables
# Copy this file to .env.local and fill in your own keys.
# NEVER commit .env.local — it's gitignored for a reason.
# =============================================================

# Groq LLM API key — https://console.groq.com
GROQ_API_KEY=your_groq_key_here

# SerpAPI key for Google Shopping (India) — https://serpapi.com
SERPAPI_KEY=your_serpapi_key_here

# Supabase project — https://supabase.com → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
